# ── Supabase (Dashboard → Settings → API) ───────────────────────────────────
# Project URL — e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / "publishable" public key (safe for the browser — still don’t leak it to git in .env.local)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role — SERVER ONLY. Never NEXT_PUBLIC_. Use in API routes / server actions only.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: absolute site URL if signup runs outside the browser (usually omit — we use window.location.origin).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email confirmation links must redirect here — whitelist in Supabase:
# Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://YOUR_DOMAIN/auth/callback

# Optional: direct Postgres for migrations (Drizzle, Prisma, etc.)
# Dashboard → Project Settings → Database → connection string (use pooler in production if you prefer)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Supabase CLI (local dev) ────────────────────────────────────────────────
# Personal access token: https://supabase.com/dashboard/account/tokens
# Then: supabase login   OR   export SUPABASE_ACCESS_TOKEN=...
#
# Apply schema: Supabase Dashboard → SQL Editor → paste each migration in order:
#   supabase/migrations/20260203180000_accounts_profiles_businesses.sql
#   supabase/migrations/20260518120000_booking_slug_and_requests.sql
#   supabase/migrations/20260519100000_dashboard_setup_fields.sql
#   supabase/migrations/20260520120000_booking_messages.sql
#   supabase/migrations/20260521100000_booking_intake_columns_and_rpc.sql
#   supabase/migrations/20260523120000_booking_inventory_voice_prompts.sql
#   supabase/migrations/20260524100000_booking_public_context_rpc.sql
#   supabase/migrations/20260525100000_venue_calendar_bookings.sql
#   supabase/migrations/20260526120000_booking_completeness.sql
#   supabase/migrations/20260527140000_platform_onboarding_wizard.sql
# Then Run (or supabase db push when CLI is linked).
# Or after CLI login/link: supabase db push

# ── Solvio voice stack (SERVER ONLY — merchants never paste keys) ─────────────
# Configure once per deployment (localhost .env.local + Vercel project env).
# ElevenLabs: Profile → API key (shown as “xi-api-key”). This is NOT a Web Push VAPID key.
SOLVIO_ELEVENLABS_API_KEY=

# Voice id for the marketing-site receptionist demo (hero / VoiceDemoPanel). Find under ElevenLabs → Voices.
# Optional if NEXT_PUBLIC_VAPI_ASSISTANT_ID + SOLVIO_VAPI_API_KEY are set: TTS derives the ElevenLabs voice Id from your Vapi assistant profile.
SOLVIO_VOICE_DEMO_VOICE_ID=

# Optional: default is eleven_multilingual_v2 — set if your workspace requires another model id.
# SOLVIO_VOICE_DEMO_MODEL_ID=eleven_multilingual_v2

SOLVIO_VAPI_API_KEY=

# Optional: richer “Generate full prompt (ChatGPT)” in Dashboard → Voice setup (server-side only).
SOLVIO_OPENAI_API_KEY=

# Model string Vapi attaches to assistants we create/sync (gpt-4o-mini is inexpensive; customize if your workspace allows).
SOLVIO_VAPI_AGENT_OPENAI_MODEL=gpt-4o-mini

# Marketing live agent (@vapi-ai/web — keys are baked in at build; use PUBLIC key only).
# Dashboard → API Keys: copy the public key into NEXT_PUBLIC_VAPI_PUBLIC_KEY (not SOLVIO_VAPI_API_KEY unless Vapi docs say otherwise).
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Assistants → your Solvio pitch agent → Assistant ID (UUID).
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
# Optional server-only assistant id (SSR homepage); client still needs NEXT_PUBLIC_VAPI_PUBLIC_KEY.
SOLVIO_MARKETING_VAPI_ASSISTANT_ID=

# ── Booking transactional comms ───────────────────────────────────────────────
# Resend (recommended for guest receipts): https://resend.com/docs
SOLVIO_RESEND_API_KEY=
SOLVIO_MAIL_FROM=Solvio <bookings@solvio.your-domain.com>

# Optional SMS when confirming bookings (guest phone must exist on the request).
# Twilio Messaging API — SERVER ONLY.
SOLVIO_TWILIO_ACCOUNT_SID=
SOLVIO_TWILIO_AUTH_TOKEN=
SOLVIO_TWILIO_FROM_NUMBER=

# Soft rate limit fingerprints for anon /book submits (recommended in production).
BOOKING_RATE_SALT=

# ── Stripe (Plans page → Checkout + Connect deposits) ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform subscription price IDs (merchant pays Solvio)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_CHECKOUT_DEFAULT_EMAIL=
# Webhook endpoint: https://YOUR_DOMAIN/api/webhooks/stripe (Connect account.updated + checkout.session.completed)

# ── Optional: Playwright (local / CI only — never commit real passwords)
# PLAYWRIGHT_DASHBOARD_EMAIL=
# PLAYWRIGHT_DASHBOARD_PASSWORD=
